{
  "name": "@penmarkdev/components",
  "version": "1.0.0",
  "description": "Penmark's reusable components for beautiful documentations.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo \"Error: no test specified\" && exit 1",
    "storybook": "storybook dev -p 6008 --no-open"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/penmarkdev/NodeKit.git"
  },
  "dependencies": {
    "@necto/assert": "^1.0.0",
    "@necto/strings": "^1.7.0",
    "@sprocketui-react/tabs": "^1.1.11",
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-storysource": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.7.0"
  }
}
